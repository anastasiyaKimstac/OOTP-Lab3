<Window x:Class="OOTP_Lab3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OOTP_Lab3"
        mc:Ignorable="d"
        Title="OOTP_Lab3 - Employee Manager with Plugins" Height="600" Width="900" 
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Plugin Toolbar -->
        <Border Grid.Row="0" Margin="0,0,0,10" Padding="5" Background="#F0F0F0" CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Base Types:" VerticalAlignment="Center" Margin="5" FontWeight="Bold"/>
                <Button Content="➕ Manager" Width="70" Margin="2" Click="Add_Click"/>
                <Button Content="👨‍💻 Dev" Width="60" Margin="2" Click="Add_Click"/>
                <Button Content="🎨 Designer" Width="70" Margin="2" Click="Add_Click"/>
                <Button Content="🧪 Tester" Width="60" Margin="2" Click="Add_Click"/>
                <Button Content="📚 Intern" Width="60" Margin="2" Click="Add_Click"/>

                <Separator Width="20"/>

                <TextBlock Text="Plugins:" VerticalAlignment="Center" Margin="5" FontWeight="Bold" 
                           Visibility="{Binding PluginButtons.Count, Converter={StaticResource CountToVisibility}}"/>
                <ItemsControl ItemsSource="{Binding PluginButtons}" Margin="2">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Employee List -->
            <Border Grid.Column="0" Margin="0,0,10,0" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#2C3E50" Padding="10" CornerRadius="5,5,0,0">
                        <TextBlock Text="📋 Employees" FontWeight="Bold" FontSize="14" Foreground="White"/>
                    </Border>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Employees}" 
                             SelectedItem="{Binding SelectedEmployee}"
                             Margin="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock FontWeight="Bold">
                                        <Run Text="{Binding EmployeeType, Mode=OneWay}"/>: <Run Text="{Binding Name, Mode=TwoWay}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="10" Foreground="Gray">
                                        💰 <Run Text="{Binding Salary, StringFormat={}{0:C0}, Mode=OneWay}"/> | 
                                        ⭐ <Run Text="{Binding YearsOfExperience, Mode=OneWay}"/> yrs
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
                        <Button Content="🗑 Delete" Width="60" Margin="2" Click="Delete_Click" Background="#E74C3C" Foreground="White"/>
                        <Button Content="💿 Save to File" Width="100" Margin="2" Click="SaveFile_Click"/>
                        <Button Content="📂 Load from File" Width="100" Margin="2" Click="LoadFile_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Panel - Edit Form -->
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#34495E" Padding="10" CornerRadius="5,5,0,0">
                        <TextBlock Text="✏️ Edit Employee" FontWeight="Bold" FontSize="14" Foreground="White"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <TextBlock Text="Name:" FontWeight="Bold" Margin="0,5"/>
                            <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Salary:" FontWeight="Bold" Margin="0,10,0,5"/>
                            <TextBox Text="{Binding EditSalary, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Experience (years):" FontWeight="Bold" Margin="0,10,0,5"/>
                            <TextBox Text="{Binding EditExperience, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="{Binding Prop1Label}" FontWeight="Bold" Margin="0,10,0,5"/>
                            <TextBox Text="{Binding Prop1Value, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="{Binding Prop2Label}" FontWeight="Bold" Margin="0,10,0,5"/>
                            <TextBox Text="{Binding Prop2Value, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="{Binding Prop3Label}" FontWeight="Bold" Margin="0,10,0,5"
                                       Visibility="{Binding ShowProp3, Converter={StaticResource BoolToVis}}"/>
                            <TextBox Text="{Binding Prop3Value, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{Binding ShowProp3, Converter={StaticResource BoolToVis}}"/>

                            <Button Content="💾 Save Changes" Margin="0,20,0,0" Height="35" 
                                    Click="Save_Click" Background="#27AE60" Foreground="White"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Margin="0,10,0,0" Padding="5" Background="#F0F0F0" CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Total: " />
                <TextBlock Text="{Binding Employees.Count}" FontWeight="Bold"/>
                <TextBlock Text=" employees | " Margin="10,0,0,0"/>
                <TextBlock Text="Plugins loaded: " />
                <TextBlock Text="{Binding PluginButtons.Count}" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>